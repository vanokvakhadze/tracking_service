{
  "name": "trackpro",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:types": "npx supabase gen types typescript --project-id lekogoghgbvmrlqcqmhv > packages/database/src/types.ts",
    "seed:demo": "node scripts/seed-demo.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "turbo clean && rimraf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
